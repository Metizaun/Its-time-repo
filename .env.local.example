## Single source of truth for the Docker-backed local environment
## Frontend (Vite)
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>
VITE_CRM_BACKEND_URL=http://localhost:3000
VITE_ENABLE_DASHBOARD_RPC=true
VITE_AGENT_TOOLS_UI_ENABLED=true

## Backend IA (Project/IA reads this root file automatically)
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

GEMINI_API_KEY=<your-gemini-key>
CRM_ANALYSIS_WORKER_MODEL=gemini-3.1-flash-lite
PIPELINE_WORKER_ENABLED=false
PIPELINE_WORKER_POLL_MS=60000
PIPELINE_WORKER_BATCH_SIZE=10
PIPELINE_WORKER_LEASE_SECONDS=600
PIPELINE_WORKER_PER_ACCOUNT_LIMIT=2
PIPELINE_CLASSIFIER_MODEL=gemini-3.1-flash-lite
OPENAI_API_KEY=<your-openai-key>
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_VISION_MODEL=gpt-4.1-mini
ELEVENLABS_TTS_ENABLED=false
ELEVENLABS_API_KEY=<your-elevenlabs-key>
# Deixe vazio: a voz deve ser salva no binding do agente, nunca como padrao global.
ELEVENLABS_DEFAULT_VOICE_ID=
ELEVENLABS_TTS_MODEL=eleven_flash_v2_5
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
TOOL_MEDIA_ALLOWED_HOSTS=
VISAGISM_TOOL_ENABLED=false
VISAGISM_INTERNAL_RUNTIME_ENABLED=true
VISAGISM_ANALYSIS_WORKER_MODEL=gemini-2.5-flash
VISAGISM_MATCHING_WORKER_MODEL=gemini-2.5-flash
VISAGISM_IMAGE_WORKER_MODEL=gpt-image-1
PRESCRIPTION_WORKER_ENABLED=true
PRESCRIPTION_WORKER_MODEL=gemini-2.5-flash
REDIS_URL=redis://localhost:6379
EVOLUTION_API_URL=https://evo.example.com
EVOLUTION_API_KEY=<your-evolution-key>
EVOLUTION_WEBHOOK_SECRET=<shared-webhook-secret>
WEBHOOK_PUBLIC_BASE_URL=https://your-crm-backend.example.com
# Filtro opcional por instancia para testes pontuais
INSTANCE_PHONE_ALLOWLISTS_JSON={"mamis":["554199031152"]}

## Meta WhatsApp API (mock by default; no real WABA required locally)
META_PROVIDER_MODE=mock
META_GRAPH_API_VERSION=v20.0
META_WEBHOOK_VERIFY_TOKEN=local-dev-verify-token
META_WEBHOOK_APP_SECRET=local-dev-app-secret
META_DEFAULT_LANGUAGE=pt_BR
META_TEMPLATES_FIXTURE_PATH=Project/IA/fixtures/meta/templates-list.json

## Gupshup (appId, appName, API key e telefone sao salvos por canal via Admin API)
GUPSHUP_WEBHOOK_SECRET=<shared-webhook-secret>

PORT=3000
NODE_ENV=development
AUTOMATION_WORKER_ENABLED=true
AUTOMATION_WORKER_POLL_MS=300000
AUTOMATION_WORKER_BATCH_SIZE=50
RB_BILLING_WORKER_ENABLED=false
RB_BILLING_WORKER_POLL_MS=60000
BI_PROJECTION_WORKER_ENABLED=false
BI_PROJECTION_BATCH_SIZE=100
CALENDAR_FOLLOWUP_ENABLED=false
CALENDAR_FOLLOWUP_DRY_RUN=true
CALENDAR_FOLLOWUP_BATCH_SIZE=25
CALENDAR_FOLLOWUP_1H_TEMPLATE=Ola, {nome}! Passando para lembrar do compromisso "{titulo}" hoje as {horario}.
# ID do template aprovado. Parametros enviados: nome, titulo, data e horario.
CALENDAR_FOLLOWUP_HSM_TEMPLATE_ID=
CALENDAR_FOLLOWUP_HSM_LANGUAGE=pt_BR
AGENT_FOLLOWUP_ENABLED=false
AGENT_FOLLOWUP_DRY_RUN=true
AGENT_FOLLOWUP_BATCH_SIZE=25
AGENT_FOLLOWUP_META_TEMPLATE_NAME=
AGENT_FOLLOWUP_META_TEMPLATE_LANGUAGE=pt_BR
UNANSWERED_FOLLOWUP_ENABLED=false
UNANSWERED_FOLLOWUP_DRY_RUN=true
UNANSWERED_FOLLOWUP_BATCH_SIZE=25
